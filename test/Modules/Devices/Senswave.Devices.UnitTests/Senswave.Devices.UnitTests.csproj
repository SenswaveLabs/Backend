    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Modules\Devices\Senswave.Devices.Application\Senswave.Devices.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\Modules\Devices\Senswave.Devices.Domain\Senswave.Devices.Domain.csproj" />
