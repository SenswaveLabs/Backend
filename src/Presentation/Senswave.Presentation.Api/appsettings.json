{
  "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:8080",
  "AllowedHosts": "*",
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:18888",
  "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
  "OTEL_SERVICE_NAME": "senswave.api",
  "Public": {
    "Version": "1.0.0"
  },
  "Cors": {
    "Enabled": true,
    "AllowedOrigins": [ "https://www.senswave.net", "https://senswave.net" ]
  },
  "Diagnostics": {
    "OpenTelemetry": {
      "Enabled": true
    },
    "Health": {
      "MainPortAccessToken": "secretK2tonkTHisIStheWay",
      "MainPortHeaderName": "Authorization",
      "Path": "/api/health",
      "Port": 5001,
      "HealthCheckTimeoutSeconds": 10
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 31,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithSpan" ]
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 25,
    "User": "test",
    "Password": "test",
    "SenderEmail": "test_sender@senswave.com",
    "SenderName": "Senswave",
    "Enabled": false,
    "UseSsl": false
  },
  "PostgreSql": {
    "Host": "localhost",
    "Port": "5432",
    "Database": "senswave",
    "Username": "postgres",
    "Password": "postgres",
    "ErrorDetail": "false"
  },
  "MessageBus": {
    "Type": "RabbitMq",
    "RabbitMq": {
      "Host": "rabbitmq://localhost",
      "Username": "guest",
      "Password": "guest"
    },
    "Kafka": {

    }
  },
  "Modules": {
    "DataSource": {
      "Brokers": {
        "IsCluster": false,
        "Client": {
          "MilisecondSpanBetweenMessagesOnSameTopic": 100,
          "MaximalSizeOfMessageInBytes": 4096,
          "ReconnectAttempts": 10,
          "ReconnectMilisecondSpanBetweenAttempts": 2500,
          "MqttV3": {
            "PublishTimeoutMiliseconds": 1500,
            "MessageTimeoutMiliseconds": 120000
          },
          "Cleanup": {
            "Enabled": true,
            "CleanupSpanMinutes": 30,
            "ClientCleanupSpanMiliseconds": 120000
          },
          "RateLimiters": {
            "MessageRateLimiter": {
              "TokenLimit": 150,
              "KeepTokenSeconds": 60
            }
          }
        },
        "Limits": {
          "InstanceMaxBrokerClients": 5000,
          "Brokers": 2,
          "BrokerSubscribtions": 300
        }
      }
    },
    "Homes": {
      "Limits": {
        "Homes": 5,
        "RoomsPerHome": 16,
        "UsersPerHome": 10
      },
      "Sharings": {
        "PasswordLength": 8,
        "ActiveInvitationsPerOwner": 10,
        "InvitationExpiresInSeconds": 900
      }
    },
    "Devices": {
      "Limits": {
        "DevicesPerHome": 30,
        "OperationsPerDevice": 30,
        "OperationValuesPerOperation": 100,
        "DashboardsPerDevice": 4
      }
    },
    "Automations": {
      "Limits": {
        "AutomationsPerHome": 16
      }
    },
    "LiveUpdates": {
      "RateLimiter": {
        "TokensPerPeriod": 5,
        "ReplenishmentPeriodSeconds": 30
      }
    },
    "Users": {
      "DeleteAccount": {
        "DelaySeconds": 10,
        "WorkerEnabled": true
      },
      "ConfirmEmailV2": {
        "SuccessRedirect": "",
        "FailureRedirect": ""
      },
      "Auth": {
        "Google": {
          "ClientId": "",
          "ClientSecret": ""
        }
      },
      "Sender": {
        "ConfirmationUrl": "",
        "ResetUrl": ""
      }
    }
  },
  "RateLimiter": {
    "Enabled": true,
    "User": {
      "Token": {
        "QueueLimit": 0,
        "TokensPerPeriod": 20,
        "TokenLimit": 100,
        "ReplenishmentPeriodSeconds": 30
      }
    },
    "Anonymous": {
      "Token": {
        "QueueLimit": 0,
        "TokensPerPeriod": 5,
        "TokenLimit": 10,
        "ReplenishmentPeriodSeconds": 30
      }
    }
  }
}