{
  "ASPNETCORE_URLS": "http://localhost:5001;http://localhost:8080;",
  "AllowedHosts": "*",
  "Public": {
    "Version": "1.0.0"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:6067",
  "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
  "OTEL_SERVICE_NAME": "senswave.dataSources.brokers.worker",
  "Diagnostics": {
    "OpenTelemetry": {
      "Enabled": true
    },
    "Health": {
      "Path": "/api/health",
      "Port": 5001,
      "HealthCheckTimeoutSeconds": 10
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 31,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithSpan" ]
  },
  "MessageBus": {
    "Type": "RabbitMq",
    "RabbitMq": {
      "Host": "rabbitmq://localhost",
      "Username": "guest",
      "Password": "guest"
    }
  },
  "Modules": {
    "DataSource": {
      "Brokers": {
        "IsCluster": false,
        "Client": {
          "MilisecondSpanBetweenMessagesOnSameTopic": 100,
          "MaximalSizeOfMessageInBytes": 4096,
          "ReconnectAttempts": 10,
          "ReconnectMilisecondSpanBetweenAttempts": 2500,
          "MqttV3": {
            "PublishTimeoutMiliseconds": 1500,
            "MessageTimeoutMiliseconds": 120000
          },
          "Cleanup": {
            "Enabled": true,
            "CleanupSpanMinutes": 30,
            "ClientCleanupSpanMiliseconds": 120000
          },
          "RateLimiters": {
            "MessageRateLimiter": {
              "TokenLimit": 150,
              "KeepTokenSeconds": 60
            }
          }
        },
        "Limits": {
          "InstanceMaxBrokerClients": 5000,
          "Brokers": 2,
          "BrokerSubscribtions": 300
        }
      }
    },
    "Homes": {
      "Limits": {
        "Homes": 5,
        "RoomsPerHome": 16,
        "UsersPerHome": 10
      },
      "Sharings": {
        "PasswordLength": 8,
        "ActiveInvitationsPerOwner": 10,
        "InvitationExpiresInSeconds": 900
      }
    },
    "Devices": {
      "Limits": {
        "DevicesPerHome": 30,
        "OperationsPerDevice": 30,
        "OperationValuesPerOperation": 100,
        "DashboardsPerDevice": 4
      }
    },
    "Automations": {
      "Limits": {
        "AutomationsPerHome": 16
      }
    },
    "LiveUpdates": {
      "RateLimiter": {
        "TokensPerPeriod": 5,
        "ReplenishmentPeriodSeconds": 30
      }
    },
    "Users": {
      "Auth": {
        "Google": {
          "ClientId": "",
          "ClientSecret": ""
        }
      }
    }
  },
  "RateLimiter": {
    "Enabled": true,
    "User": {
      "Token": {
        "QueueLimit": 0,
        "TokensPerPeriod": 20,
        "TokenLimit": 100,
        "ReplenishmentPeriodSeconds": 30
      }
    },
    "Anonymous": {
      "Token": {
        "QueueLimit": 0,
        "TokensPerPeriod": 5,
        "TokenLimit": 10,
        "ReplenishmentPeriodSeconds": 30
      }
    }
  }
}